{
  "version": 2,
  "builds": [
    {
      "src": "creatifinity_blog/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.10" }
    }
  ],
  "buildCommand": "python manage.py collectstatic --noinput",
  "routes": [{ "src": "/(.*)", "dest": "creatifinity_blog/wsgi.py" }]
}
